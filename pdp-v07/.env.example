# ═══════════════════════════════════════════════════════════════════
# PHONG DAILY PRESS v0.6 — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════

# ── Supabase (REQUIRED) ──────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Writing Engine: Anthropic Claude (REQUIRED for promo mode) ────────
# Primary AI writing brain. Claude Sonnet 4.6 is the default model.
# If not set here, each user must provide their own key in the browser.
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Model override (optional — change only if you want a different Claude model)
# ANTHROPIC_MODEL=claude-sonnet-4-6    # Optional — defaults to claude-sonnet-4-6 if unset

# ── Operations Brain: OpenAI GPT (OPTIONAL) ──────────────────────────
# GPT remains available for research, fact extraction, tagging, analytics.
# Not required. Users can also bring their own OpenAI key via the browser.
# OPENAI_API_KEY=sk-proj-...

# ── Owner Panel Security (REQUIRED if using Owner Panel) ─────────────
# This secret authenticates all owner-level API calls (promo creation,
# user management, billing overview). Use a strong random string.
# Generate one: openssl rand -hex 32
OWNER_ADMIN_SECRET=change-this-to-a-strong-random-secret

# ── Deployment (set automatically on Vercel / Netlify) ───────────────
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
